			<text:p text:style-name="P23"/>
			<table:table table:name="Table6" table:style-name="Table6">
				<table:table-column table:style-name="Table6.A"/>
				<table:table-column table:style-name="Table6.B"/>
				<table:table-row table:style-name="Table6.1">
					<table:table-cell table:style-name="Table6.A1" office:value-type="string">
						<text:p text:style-name="P24">Please indicate whether the research involves children and will therefore be subject to Section 19 of the Vulnerable Children’s Act 2014?</text:p>
					</table:table-cell>
					<table:table-cell table:style-name="Table6.B1" office:value-type="string">
						<text:p text:style-name="P24">Yes</text:p>
					</table:table-cell>
				</table:table-row>
				<table:table-row table:style-name="Table6.1">
					<table:table-cell table:style-name="Table6.A2" office:value-type="string">
						<text:p text:style-name="P24">If you have answered yes in above question. Does your institution have a Child Protection Policy?*</text:p>
					</table:table-cell>
					<table:table-cell table:style-name="Table6.B2" office:value-type="string">
						<text:p text:style-name="P24">No - I wish to use the Royal Society policy. </text:p>
					</table:table-cell>
				</table:table-row>
			</table:table>
			<text:p text:style-name="Standard"><text:span text:style-name="T10">If the host organisation not have a child protection policy, the host organisation agrees to comply with the policy of the Society (</text:span><text:a xlink:type="simple" xlink:href="https://royalsociety.org.nz/who-we-are/our-rules-and-codes/policy-on-child-protection/child-protection-policy/" text:style-name="Internet_20_link" text:visited-style-name="Visited_20_Internet_20_Link"><text:span text:style-name="Internet_20_link"><text:span text:style-name="T10">https://royalsociety.org.nz/who-we-are/our-rules-and-codes/policy-on-child-protection/child-protection-policy/</text:span></text:span></text:a><text:span text:style-name="T10">).</text:span></text:p>
